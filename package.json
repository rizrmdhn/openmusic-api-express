{
  "name": "openmusic-api",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "pnpm with-env tsx watch src/server.ts",
    "db:push": "pnpm with-env drizzle-kit push",
    "db:generate": "pnpm with-env drizzle-kit generate",
    "db:studio": "pnpm with-env drizzle-kit studio",
    "db:migrate": "pnpm with-env drizzle-kit migrate",
    "build": "tsc --project tsconfig.json",
    "start": "pnpm with-env tsx src/server.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "check-types": "tsc --noEmit",
    "with-env": "dotenv -e .env --",
    "with-env:local": "dotenv -e .env.local -e .env --",
    "with-env:prod": "dotenv -e .env.production -e .env --"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@t3-oss/env-core": "^0.13.10",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "postgres": "^3.4.8",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "newman": "^6.2.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
